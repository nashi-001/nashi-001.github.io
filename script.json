// ===== 状態管理 =====
let kanjiData = null;
let currentCategory = "low";
let currentGrade = "one";
let currentKanji = null;     // 現在の漢字キー (例: "日")
let currentEntry = null;     // 現在の問題データ
let isAnswerRevealed = false;

// 統計
let stats = {
    correct: 0,
    wrong: 0,
    total: 0
};

// 学年ラベルマッピング
const gradeLabels = {
    "low|one": "小学1年",
    "low|two": "小学2年",
    "low|three": "小学3年",
    "low|four": "小学4年",
    "low|five": "小学5年",
    "low|six": "小学6年"
};

// ===== DOM要素 =====
const kanjiTextEl = document.getElementById("kanji-text");
const kanjiDisplayEl = document.getElementById("kanji-display");
const answerRevealEl = document.getElementById("answer-reveal");
const answerKanjiEl = document.getElementById("answer-kanji");
const gradeLabelEl = document.getElementById("grade-label");
const correctCountEl = document.getElementById("correct-count");
const wrongCountEl = document.getElementById("wrong-count");
const totalCountEl = document.getElementById("total-count");
const gradeModal = document.getElementById("grade-modal");

// ===== 初期化 =====
document.addEventListener("DOMContentLoaded", () => {
    // kanji.jsonを読み込み
    fetch("kanji.json")
        .then(response => response.json())
        .then(data => {
            kanjiData = data;
            // localStorageから統計を復元
            loadStats();
            updateStatsDisplay();
            // 最初の問題を出題
            showNextKanji();
        })
        .catch(err => {
            console.error("kanji.jsonの読み込みに失敗:", err);
            kanjiTextEl.textContent = "データ読み込みエラー";
        });
});

// ===== 統計の保存/復元 =====
function loadStats() {
    const saved = localStorage.getItem("kanji_stats");
    if (saved) {
        try {
            stats = JSON.parse(saved);
        } catch (e) {
            stats = { correct: 0, wrong: 0, total: 0 };
        }
    }
}

function saveStats() {
    localStorage.setItem("kanji_stats", JSON.stringify(stats));
}

function updateStatsDisplay() {
    correctCountEl.textContent = stats.correct;
    wrongCountEl.textContent = stats.wrong;
    totalCountEl.textContent = stats.total;
}

// ===== 漢字を出題する =====
function showNextKanji() {
    if (!kanjiData) return;

    const gradeData = kanjiData[currentCategory]?.[currentGrade];
    if (!gradeData || Object.keys(gradeData).length === 0) {
        kanjiTextEl.textContent = "この学年にはデータがありません";
        answerRevealEl.classList.add("hidden");
        return;
    }

    // ランダムに漢字を選ぶ
    const kanjiKeys = Object.keys(gradeData);
    const randomKey = kanjiKeys[Math.floor(Math.random() * kanjiKeys.length)];
    const entries = gradeData[randomKey];

    // エントリーの中からランダムに1つ選ぶ
    const entryKeys = Object.keys(entries);
    const randomEntryKey = entryKeys[Math.floor(Math.random() * entryKeys.length)];
    const entry = entries[randomEntryKey];

    currentKanji = randomKey;
    currentEntry = entry;
    isAnswerRevealed = false;

    // 問題文を構築: 漢字の部分をひらがなに置き換えて表示
    displayQuestion(entry.string, entry.hiragana, entry.point, randomKey);

    // 答えを隠す
    answerRevealEl.classList.add("hidden");
    answerKanjiEl.textContent = randomKey;

    // アニメーションリセット
    kanjiDisplayEl.style.animation = "none";
    kanjiDisplayEl.offsetHeight; // reflow
    kanjiDisplayEl.style.animation = "fadeIn 0.3s ease";
}

// 問題文の構築
function displayQuestion(str, hiragana, point, kanji) {
    // pointの位置にある漢字をひらがなに置き換える
    // pointは文字列中の漢字の開始位置
    const before = str.substring(0, point);
    const after = str.substring(point + kanji.length);

    kanjiTextEl.innerHTML = "";

    if (before) {
        kanjiTextEl.appendChild(document.createTextNode(before));
    }

    const blankSpan = document.createElement("span");
    blankSpan.className = "hiragana-blank";
    blankSpan.textContent = hiragana;
    kanjiTextEl.appendChild(blankSpan);

    if (after) {
        kanjiTextEl.appendChild(document.createTextNode(after));
    }
}

// ===== ボタンイベント =====

// 失敗ボタン
document.getElementById("fail").addEventListener("click", () => {
    if (!currentKanji) return;

    stats.wrong++;
    stats.total++;
    saveStats();
    updateStatsDisplay();

    // 答えを表示
    answerRevealEl.classList.remove("hidden");

    // フラッシュエフェクト
    kanjiDisplayEl.classList.remove("flash-wrong");
    kanjiDisplayEl.offsetHeight;
    kanjiDisplayEl.classList.add("flash-wrong");

    isAnswerRevealed = true;
});

// 成功ボタン
document.getElementById("success").addEventListener("click", () => {
    if (!currentKanji) return;

    stats.correct++;
    stats.total++;
    saveStats();
    updateStatsDisplay();

    // 答えを表示
    answerRevealEl.classList.remove("hidden");

    // フラッシュエフェクト
    kanjiDisplayEl.classList.remove("flash-correct");
    kanjiDisplayEl.offsetHeight;
    kanjiDisplayEl.classList.add("flash-correct");

    isAnswerRevealed = true;
});

// 答えを見るボタン
document.getElementById("show-answer").addEventListener("click", () => {
    if (!currentKanji) return;

    // 答えを表示
    answerRevealEl.classList.remove("hidden");
    isAnswerRevealed = true;
});

// 次の漢字ボタン
document.getElementById("next").addEventListener("click", () => {
    showNextKanji();
});

// 学年選択ボタン
document.getElementById("select").addEventListener("click", () => {
    gradeModal.classList.remove("hidden");
    updateGradeButtons();
});

// モーダルを閉じる
document.getElementById("modal-close").addEventListener("click", () => {
    gradeModal.classList.add("hidden");
});

// モーダル背景クリックで閉じる
gradeModal.addEventListener("click", (e) => {
    if (e.target === gradeModal) {
        gradeModal.classList.add("hidden");
    }
});

// 学年ボタンのクリック
document.querySelectorAll(".grade-btn").forEach(btn => {
    btn.addEventListener("click", () => {
        currentCategory = btn.dataset.category;
        currentGrade = btn.dataset.grade;

        const key = `${currentCategory}|${currentGrade}`;
        gradeLabelEl.textContent = gradeLabels[key] || currentGrade;

        updateGradeButtons();
        gradeModal.classList.add("hidden");
        showNextKanji();
    });
});

// 学年ボタンのアクティブ状態を更新
function updateGradeButtons() {
    document.querySelectorAll(".grade-btn").forEach(btn => {
        if (btn.dataset.category === currentCategory && btn.dataset.grade === currentGrade) {
            btn.classList.add("active");
        } else {
            btn.classList.remove("active");
        }
    });
}

// キーボードショートカット
document.addEventListener("keydown", (e) => {
    if (!gradeModal.classList.contains("hidden")) return; // モーダル開いてる時は無視

    switch (e.key) {
        case "ArrowLeft":
        case "1":
            document.getElementById("fail").click();
            break;
        case "ArrowRight":
        case "3":
            document.getElementById("success").click();
            break;
        case "ArrowDown":
        case "2":
            document.getElementById("show-answer").click();
            break;
        case " ":
        case "Enter":
            e.preventDefault();
            document.getElementById("next").click();
            break;
    }
});
